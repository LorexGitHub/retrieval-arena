ate driving machine brand slogan."], "scores": [0.7997226151975443, 0.7410246691098367, 0.7231850889549283, 0.6584766424966813, 0.6533574657234241], "model_name": "bge-large", "document_ids": ["Mercedes-Benz", "Audi", "Porsche", "Volvo", "BMW"]}}