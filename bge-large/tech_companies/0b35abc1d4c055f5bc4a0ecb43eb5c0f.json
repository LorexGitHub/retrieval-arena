s."], "scores": [0.8191243019592233, 0.665199803985013, 0.6485564204697896, 0.6143262789204522, 0.6138486586287197], "model_name": "bge-large", "document_ids": ["Microsoft", "Amazon", "Apple", "Intel", "Salesforce"]}}