ts."], "scores": [0.6596297024036866, 0.49539614754149663, 0.48351255206360294, 0.46938294143859155, 0.4688043215846381], "model_name": "harrier", "document_ids": ["Italian", "Greek", "Spanish", "Peruvian", "Thai"]}}