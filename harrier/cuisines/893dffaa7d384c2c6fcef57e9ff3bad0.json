his cuisine."], "scores": [0.6362434056443108, 0.5255701249921182, 0.5133729625593387, 0.48781316426324633, 0.4876532535105764], "model_name": "harrier", "document_ids": ["Japanese", "Thai", "Peruvian", "Italian", "Chinese"]}}